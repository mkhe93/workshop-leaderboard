{
  "name": "Devbox Remote Container",
  "image": "ghcr.io/mkhe93/workshop-leaderboard:latest",
  "runArgs": ["--env-file",".devcontainer/devcontainer.env"],
  "workspaceMount": "source=${localWorkspaceFolder},target=/code,type=bind,consistency=cached",
  "workspaceFolder": "/code",
  "remoteUser": "node",
  "containerUser": "node",
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/ccr_config.json,target=/home/node/.claude-code-router/config.json,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "mutantdino.resourcemonitor@1.0.7"
      ]
    }
  },
  "hostRequirements": {
    "cpus": 3,
    "memory": "8gb"
  },
  "forwardPorts": [
    9080
  ],
  "onCreateCommand": {
	"diagnostics": "whoami && id && pwd && ls -lah",
    "backend_install": "cd backend && uv sync",
    "frontend_install": "cd frontend && npm ci",
    "add_marketplace": "claude plugin marketplace add fcoury/conductor"
  },
  // executed after onCreateCommand has finished
  "postCreateCommand": {
    "install_conductor": "claude plugin install --scope local conductor"
  }
}
